# ═══════════════════════════════════════════
# Media Stack VPS — Variables d'environnement
# ═══════════════════════════════════════════
# Copier ce fichier en .env et remplacer toutes les valeurs CHANGE_ME

# Système
PUID=1000
PGID=1000
TZ=Europe/Paris

# Chemin racine du volume de stockage (hardlinks qBit ↔ Sonarr/Radarr)
# Doit contenir /downloads et /media sur le MÊME filesystem
DATA_PATH=/mnt/HC_Volume_104978745

# ── VPN Mullvad WireGuard ──────────────────
# Générer sur https://mullvad.net/fr/account/wireguard-config
WIREGUARD_PRIVATE_KEY=CHANGE_ME
WIREGUARD_ADDRESSES=CHANGE_ME

# ── Tunnel WireGuard VPS → Freebox ────────
# Valeurs depuis le fichier .conf téléchargé dans Freebox OS → Serveur VPN → WireGuard
WG_FREEBOX_PRIVATE_KEY=CHANGE_ME
WG_FREEBOX_ADDRESS=CHANGE_ME
WG_FREEBOX_PUBLIC_KEY=CHANGE_ME
WG_FREEBOX_ENDPOINT=CHANGE_ME
WG_FREEBOX_PORT=22563

# ── Freebox SFTP (pour rclone, via tunnel) ──
# IP de la VM Freebox joignable via le tunnel WireGuard
# Si Docker tourne sur une VM (ex: Freebox Ultra), utiliser l'IP LAN de la VM (ex: 192.168.1.250)
# et non l'IP WireGuard du routeur (192.168.27.x). Vérifier avec : nc -zv IP 2222
FREEBOX_WG_IP=CHANGE_ME
FREEBOX_SFTP_PORT=2222
FREEBOX_SFTP_USER=mediastack
FREEBOX_MEDIA_PATH=/data

# ── Domaine (pour nginx reverse proxy) ────
# Doit pointer vers l'IP du VPS (DNS A record via Cloudflare)
DOMAIN=CHANGE_ME

# ── Nginx Basic Auth ────────────────────
# Utilisateur et mot de passe pour l'accès aux services (Sonarr, Radarr, etc.)
# Le hash sera généré automatiquement par setup.sh via htpasswd
NGINX_USER=CHANGE_ME
NGINX_PASSWORD=CHANGE_ME

# ── qBittorrent ───────────────────────
# Mot de passe WebUI (appliqué automatiquement à chaque démarrage)
QBIT_PASSWORD=CHANGE_ME

# ── Homepage Dashboard ─────────────────
# Identifiants pour l'accès au dashboard (htpasswd séparé)
HOMEPAGE_USER=AdminADR3
HOMEPAGE_PASSWORD=CHANGE_ME

# Clés API des services (récupérées depuis les configs après premier démarrage)
HOMEPAGE_RADARR_KEY=CHANGE_ME
HOMEPAGE_SONARR_KEY=CHANGE_ME
HOMEPAGE_PROWLARR_KEY=CHANGE_ME
HOMEPAGE_OVERSEERR_KEY=CHANGE_ME

# ── SSH (pour harden.sh) ─────────────────
SSH_PORT=2222

# ── Port qBittorrent (via Gluetun) ──────
PORT_QBITTORRENT=8080

# ── Discord Notifications ──────────────────
# Webhook URL: https://discord.com/api/webhooks/{WEBHOOK_ID}/{WEBHOOK_TOKEN}
DISCORD_WEBHOOK_ID=CHANGE_ME
DISCORD_WEBHOOK_TOKEN=CHANGE_ME

# ── Notifiarr ────────────────────────────
# API key from https://notifiarr.com (create free account)
NOTIFIARR_API_KEY=CHANGE_ME

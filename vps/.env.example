# ═══════════════════════════════════════════
# Media Stack VPS — Variables d'environnement
# ═══════════════════════════════════════════
# Copier ce fichier en .env et remplacer toutes les valeurs CHANGE_ME

# Systeme
PUID=1000
PGID=1000
TZ=Europe/Paris

# ── Tunnel WireGuard VPS -> Freebox ────────
# Valeurs depuis le fichier .conf telecharge dans Freebox OS -> Serveur VPN -> WireGuard
WG_FREEBOX_PRIVATE_KEY=CHANGE_ME
WG_FREEBOX_ADDRESS=CHANGE_ME
WG_FREEBOX_PUBLIC_KEY=CHANGE_ME
WG_FREEBOX_ENDPOINT=CHANGE_ME
WG_FREEBOX_PORT=22563

# ── Freebox (qBittorrent + CIFS, via tunnel WireGuard) ──
# IP de la VM Freebox joignable via le tunnel WireGuard
# Si Docker tourne sur une VM (ex: Freebox Ultra), utiliser l'IP LAN de la VM (ex: 192.168.1.250)
# et non l'IP WireGuard du routeur (192.168.27.x). Verifier avec : nc -zv IP 8080
FREEBOX_WG_IP=CHANGE_ME

# ── Domaine (pour nginx reverse proxy) ────
# Doit pointer vers l'IP du VPS (DNS A record via Cloudflare)
DOMAIN=CHANGE_ME

# ── Authelia SSO ────────────────────────────
# Portail d'authentification unique pour tous les services
# Les secrets doivent faire au minimum 32 caracteres
# Generer avec : openssl rand -hex 32
AUTHELIA_JWT_SECRET=CHANGE_ME
AUTHELIA_SESSION_SECRET=CHANGE_ME
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME
AUTHELIA_USER=CHANGE_ME
AUTHELIA_PASSWORD=CHANGE_ME
AUTHELIA_EMAIL=CHANGE_ME

# ── qBittorrent ───────────────────────
# Mot de passe WebUI (applique automatiquement a chaque demarrage)
QBIT_PASSWORD=CHANGE_ME

# ── Homepage Dashboard ─────────────────
# Cles API des services (recuperees depuis les configs apres premier demarrage)
HOMEPAGE_RADARR_KEY=CHANGE_ME
HOMEPAGE_SONARR_KEY=CHANGE_ME
HOMEPAGE_PROWLARR_KEY=CHANGE_ME
HOMEPAGE_SEERR_KEY=CHANGE_ME

# ── Hetzner Volume ───────────────────────
# Point de montage du volume Hetzner Cloud (pour widget disk Homepage)
HETZNER_VOLUME_PATH=/mnt/HC_Volume_CHANGE_ME

# ── SSH (pour harden.sh) ─────────────────
SSH_PORT=2222


# ── Discord Watchtower (salon #systeme) ──────
# Webhook du salon Discord pour les notifications Watchtower (mises a jour containers)
# Creer un webhook dans le salon Discord souhaite, URL: https://discord.com/api/webhooks/{ID}/{TOKEN}
DISCORD_WATCHTOWER_WEBHOOK_ID=CHANGE_ME
DISCORD_WATCHTOWER_WEBHOOK_TOKEN=CHANGE_ME

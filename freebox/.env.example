# ═══════════════════════════════════════════
# Media Stack Freebox — Variables d'environnement
# ═══════════════════════════════════════════
# Copier ce fichier en .env et remplacer toutes les valeurs CHANGE_ME

# Systeme
PUID=1000
PGID=1000
TZ=Europe/Paris

# Chemin racine des donnees sur la VM (contient downloads/ et media/)
# Doit contenir /downloads et /media sur le MEME filesystem (pour les hardlinks)
DATA_PATH=/data

# Chemin des medias (sous-repertoire de DATA_PATH)
MEDIA_PATH=/data/media

# ── VPN ProtonVPN WireGuard (pour les torrents + port forwarding) ──
# Generer sur https://account.protonvpn.com/downloads
# Plateforme: GNU/Linux, Protocole: WireGuard, cocher NAT-PMP (Port Forwarding)
# IMPORTANT : changer le /32 de l'adresse en /28
WIREGUARD_PRIVATE_KEY=CHANGE_ME
WIREGUARD_ADDRESSES=CHANGE_ME
# Pays du serveur VPN (Netherlands, Sweden, etc.)
VPN_SERVER_COUNTRY=Netherlands

# ── qBittorrent ──────────────────────────
# Mot de passe WebUI (applique automatiquement a chaque demarrage)
QBIT_PASSWORD=CHANGE_ME

# ── Reseau WireGuard ─────────────────────
# IP de cette machine sur le tunnel WireGuard (pour bind des ports gluetun)
FREEBOX_WG_IP=CHANGE_ME


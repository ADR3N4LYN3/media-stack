# ═══════════════════════════════════════════
# Media Stack Freebox — Variables d'environnement
# ═══════════════════════════════════════════
# Copier ce fichier en .env et remplacer toutes les valeurs CHANGE_ME

# Système
PUID=1000
PGID=1000
TZ=Europe/Paris

# IP locale de la Freebox
FREEBOX_IP=CHANGE_ME

# Token Plex (valable 4 minutes, générer sur https://plex.tv/claim)
PLEX_CLAIM=CHANGE_ME

# Chemin NVMe sur la Freebox
MEDIA_PATH=/mnt/NVMe/media
